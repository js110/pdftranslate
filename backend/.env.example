REDIS_URL=redis://redis:6379/0
SESSION_TTL_MINUTES=120
MAX_UPLOAD_MB=30
RENDER_DPI=160
HIGH_PRIORITY_QUEUE=page_high
NORMAL_PRIORITY_QUEUE=page_normal
MAX_RETRIES_PER_PROVIDER=2
BATCH_SEGMENT_SIZE=36
BATCH_SEGMENT_CHAR_LIMIT=8000
TRANSLATION_TEMPERATURE=0.2
ENABLE_STRICT_LOW_QUALITY_RETRY=false
CLEAR_TRANSLATION_MEMORY_ON_RETRY=false
ENABLE_IMAGE_OCR=false
ENABLE_REMOTE_IMAGE_OCR=false
REMOTE_OCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
REMOTE_OCR_TOKEN=
REMOTE_OCR_MODEL=PaddleOCR-VL-1.5
REMOTE_OCR_TIMEOUT_SEC=30
REMOTE_OCR_POLL_INTERVAL_SEC=5
REMOTE_OCR_MAX_WAIT_SEC=180
REMOTE_OCR_USE_DOC_ORIENTATION_CLASSIFY=false
REMOTE_OCR_USE_DOC_UNWARPING=false
REMOTE_OCR_USE_CHART_RECOGNITION=false
